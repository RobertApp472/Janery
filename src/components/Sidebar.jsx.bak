import React from 'react';

// Sidebar appears on all screens (desktop and mobile), toggle button only on mobile
export default function Sidebar({ people, onPersonClick, isOpen, toggleSidebar }) {
  return (
    <>
      {/* Sidebar toggle button (mobile only) */}
      <button
        className="fixed top-4 left-4 z-50 bg-white border-2 border-red-500 rounded-full p-2 shadow-lg md:hidden"
        onClick={toggleSidebar}
        aria-label={isOpen ? 'Ocultar barra lateral' : 'Mostrar barra lateral'}
      >
        <span className="text-red-500 font-bold">☰</span>
      </button>

      {/* Sidebar (visible on all screens) */}
      <div
        className={`fixed top-0 left-0 h-full w-64 bg-white shadow-lg z-40 transition-transform duration-300 border-4 border-red-500
          ${isOpen ? 'translate-x-0' : '-translate-x-full'}
          md:translate-x-0 md:static md:block`}
      >
        <div className="flex justify-between items-center p-4 border-b">
          <h2 className="text-lg font-bold text-red-500">Personas</h2>
          <button onClick={toggleSidebar} className="text-red-500 font-bold text-xl md:hidden">×</button>
        </div>
        <ul className="p-4 space-y-2 overflow-y-auto h-[calc(100%-64px)]">
          {people.map((person) => (
            <li key={person.id}>
              <button
                className="w-full text-left px-4 py-2 rounded hover:bg-red-100 focus:bg-red-200"
                onClick={() => onPersonClick(person)}
              >
                {person.nombre}
              </button>
            </li>
          ))}
        </ul>
      </div>
    </>
  );
}
